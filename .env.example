# ── Demo app ───────────────────────────────────────────────────────────────────
DEMO_POSTGRES_DB=demo_db
DEMO_DATABASE_URL=postgresql+asyncpg://appuser:apppassword@postgres:5432/demo_db

# ── Mariland app ───────────────────────────────────────────────────────────────
MARILAND_POSTGRES_DB=mariland_db
MARILAND_DATABASE_URL=postgresql+asyncpg://appuser:apppassword@postgres:5432/mariland_db
MARILAND_CORS_ORIGINS=http://localhost:5174
VITE_MARILAND_API_BASE_URL=http://localhost:8001

# ── Shared infra ───────────────────────────────────────────────────────────────
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── App config ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Frontend ───────────────────────────────────────────────────────────────────
DEMO_CORS_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000
